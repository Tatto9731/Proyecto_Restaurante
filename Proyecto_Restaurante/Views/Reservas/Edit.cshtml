@model Proyecto_Restaurante.Models.Reserva

@{
    ViewData["Title"] = "Editar Reserva";
}

<div class="card shadow">
    <div class="card-header bg-warning">
        <h4 class="mb-0">✏️ Editar Reserva</h4>
    </div>

    <div class="card-body">
        <form asp-action="Edit">

            <input type="hidden" asp-for="ReservaId" />

            <div class="mb-3">
                <label asp-for="ClienteId" class="form-label fw-semibold"></label>
                <select asp-for="ClienteId" class="form-select" asp-items="ViewBag.ClienteId"></select>
            </div>

            <div class="mb-3">
                <label asp-for="MesaId" class="form-label fw-semibold"></label>
                <select asp-for="MesaId" class="form-select" asp-items="ViewBag.MesaId"></select>
            </div>

            <div class="mb-3">
                <label asp-for="Fecha" class="form-label fw-semibold"></label>
                <input asp-for="Fecha" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="CantidadPersonas" class="form-label fw-semibold"></label>
                <input asp-for="CantidadPersonas" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Estado" class="form-label fw-semibold"></label>
                <input asp-for="Estado" class="form-control" />
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">← Volver</a>
                <button type="submit" class="btn btn-gold">Guardar Cambios</button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}