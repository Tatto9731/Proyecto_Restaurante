@model IEnumerable<Proyecto_Restaurante.Models.Reserva>

@{
    ViewData["Title"] = "Reservas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">📅 Reservas</h2>
    <a asp-action="Create" class="btn btn-gold">+ Nueva Reserva</a>
</div>

<table class="table table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Fecha</th>
            <th>Personas</th>
            <th>Estado</th>
            <th>Cliente</th>
            <th>Mesa</th>
            <th class="text-end">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>📆 @item.Fecha</td>
                <td>👥 @item.CantidadPersonas</td>
                <td>
                    <span class="badge bg-secondary">@item.Estado</span>
                </td>
                <td>👤 @item.Cliente?.ClienteId</td>
                <td>🪑 @item.Mesa?.MesaId</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@item.ReservaId" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.ReservaId" class="btn btn-sm btn-info text-white">Ver</a>
                    <a asp-action="Delete" asp-route-id="@item.ReservaId" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>