@model Proyecto_Restaurante.Models.Reserva

@{
    ViewData["Title"] = "Nueva Reserva";
}

<div class="card shadow">
    <div class="card-header bg-dark text-white">
        <h4 class="mb-0">📅 Crear Reserva</h4>
    </div>

    <div class="card-body">
        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="ClienteId" class="form-label fw-semibold"></label>
                <select asp-for="ClienteId" class="form-select" asp-items="ViewBag.ClienteId">
                    <option value="">-- Seleccione cliente --</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="MesaId" class="form-label fw-semibold"></label>
                <select asp-for="MesaId" class="form-select" asp-items="ViewBag.MesaId">
                    <option value="">-- Seleccione mesa --</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Fecha" class="form-label fw-semibold"></label>
                <input asp-for="Fecha" class="form-control" />
                <span asp-validation-for="Fecha" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CantidadPersonas" class="form-label fw-semibold"></label>
                <input asp-for="CantidadPersonas" class="form-control" />
                <span asp-validation-for="CantidadPersonas" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Estado" class="form-label fw-semibold"></label>
                <select asp-for="Estado" class="form-select" asp-items="ViewBag.Estado">
                    <option value="">-- Seleccione estado --</option>
                </select>
                <span asp-validation-for="Estado" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">← Volver</a>
                <button type="submit" class="btn btn-gold">Guardar</button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}