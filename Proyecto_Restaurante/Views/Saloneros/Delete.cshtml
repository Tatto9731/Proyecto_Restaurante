@model Proyecto_Restaurante.Models.Salonero

@{
    ViewData["Title"] = "Eliminar Salonero";
}

<div class="card shadow border-danger">
    <div class="card-header bg-danger text-white">
        <h4 class="mb-0">⚠️ Eliminar Salonero</h4>
    </div>

    <div class="card-body">

        <p>¿Seguro que deseas eliminar este salonero?</p>

        <ul>
            <li><strong>Nombre:</strong> @Model.Nombre</li>
        </ul>

        <form asp-action="Delete">
            <input type="hidden" asp-for="SaloneroId" />

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-danger">Eliminar</button>
            </div>

        </form>

    </div>
</div>