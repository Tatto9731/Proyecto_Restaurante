@model Proyecto_Restaurante.Models.Salonero

@{
    ViewData["Title"] = "Nuevo Salonero";
}

<div class="card shadow">
    <div class="card-header bg-dark text-white">
        <h4 class="mb-0">➕ Crear Salonero</h4>
    </div>

    <div class="card-body">
        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-semibold"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">← Volver</a>
                <button type="submit" class="btn btn-gold">Guardar</button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}