@model Proyecto_Restaurante.Models.Salonero

@{
    ViewData["Title"] = "Detalles Salonero";
}

<div class="container">
    <h2 class="mb-3">Detalles del Salonero</h2>

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Nombre</dt>
                <dd class="col-sm-9">@Model.Nombre</dd>
            </dl>

            <a asp-action="Edit" asp-route-id="@Model?.SaloneroId" class="btn btn-primary">Editar</a>
            <a asp-action="Index" class="btn btn-secondary">Volver</a>
        </div>
    </div>
</div>