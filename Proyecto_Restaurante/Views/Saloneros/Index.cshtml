@model IEnumerable<Proyecto_Restaurante.Models.Salonero>

@{
    ViewData["Title"] = "Saloneros";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Saloneros</h2>
        <a asp-action="Create" class="btn btn-primary">Nuevo Salonero</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Nombre</td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.SaloneroId" class="btn btn-sm btn-warning">Editar</a>
                                <a asp-action="Details" asp-route-id="@item.SaloneroId" class="btn btn-sm btn-info">Ver</a>
                                <a asp-action="Delete" asp-route-id="@item.SaloneroId" class="btn btn-sm btn-danger">Eliminar</a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>
</div>