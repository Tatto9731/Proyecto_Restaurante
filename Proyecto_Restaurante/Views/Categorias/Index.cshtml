@model IEnumerable<Proyecto_Restaurante.Models.Categoria>

@{
    ViewData["Title"] = "Categorías";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">📂 Categorías</h2>
    <a asp-action="Create" class="btn btn-gold">+ Nueva Categoría</a>
</div>

<table class="table table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th class="text-end">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="fw-semibold">@item.Nombre</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@item.CategoriaId" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.CategoriaId" class="btn btn-sm btn-info text-white">Ver</a>
                    <a asp-action="Delete" asp-route-id="@item.CategoriaId" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>