@model IEnumerable<Proyecto_Restaurante.Models.Mesa>

@{
    ViewData["Title"] = "Mesas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">🪑 Mesas</h2>
    <a asp-action="Create" class="btn btn-gold">+ Nueva Mesa</a>
</div>

<table class="table table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Número</th>
            <th>Capacidad</th>
            <th class="text-end">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="fw-semibold">@item.NumeroMesa</td>
                <td>@item.Capacidad personas</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@item.MesaId" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.MesaId" class="btn btn-sm btn-info text-white">Ver detalles</a>
                    <a asp-action="Delete" asp-route-id="@item.MesaId" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>