@model IEnumerable<Proyecto_Restaurante.Models.Mesa>

@{
    ViewData["Title"] = "Mesas";
}

<h2>Mesas</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">+ Nueva Mesa</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Número</th>
            <th>Capacidad</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.NumeroMesa</td>
                <td>@item.Capacidad personas</td>
                <td>
                    @if (item.Estado == "Ocupada")
                    {
                        <span class="badge bg-danger">Ocupada</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Disponible</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.MesaId">Editar</a> |
                    <a asp-action="Details" asp-route-id="@item.MesaId">Ver detalles</a> |
                    <a asp-action="Delete" asp-route-id="@item.MesaId">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>