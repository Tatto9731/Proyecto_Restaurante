@model Proyecto_Restaurante.Models.Factura

@{
    ViewData["Title"] = "Editar Factura";
}

<div class="card shadow">
    <div class="card-header bg-warning">
        <h4 class="mb-0">✏️ Editar Factura</h4>
    </div>

    <div class="card-body">
        <form asp-action="Edit">

            <input type="hidden" asp-for="FacturaId" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label asp-for="OrdenId" class="form-label fw-semibold"></label>
                    <select asp-for="OrdenId" class="form-select" asp-items="ViewBag.OrdenId"></select>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="MetodoPago" class="form-label fw-semibold"></label>
                    <select asp-for="MetodoPago" class="form-select">
                        <option>Efectivo</option>
                        <option>Tarjeta</option>
                        <option>Sinpe</option>
                    </select>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Subtotal"></label>
                    <input asp-for="Subtotal" id="Subtotal" class="form-control" />
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Impuestos"></label>
                    <input asp-for="Impuestos" id="Impuestos" class="form-control" />
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Total"></label>
                    <input asp-for="Total" id="Total" class="form-control fw-bold bg-light" readonly />
                </div>

                <div class="col-md-12 mb-3">
                    <label asp-for="NumeroFactura"></label>
                    <input asp-for="NumeroFactura" class="form-control" />
                </div>

            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">← Volver</a>
                <button type="submit" class="btn btn-gold">Guardar Cambios</button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        function calcularTotal() {
            let subtotal = parseFloat(document.getElementById('Subtotal').value) || 0;
            let impuestos = parseFloat(document.getElementById('Impuestos').value) || 0;
            let total = subtotal + impuestos;

            document.getElementById('Total').value = total.toFixed(2);
        }

        document.getElementById('Subtotal').addEventListener('input', calcularTotal);
        document.getElementById('Impuestos').addEventListener('input', calcularTotal);

        window.addEventListener('load', calcularTotal);
    </script>
}   