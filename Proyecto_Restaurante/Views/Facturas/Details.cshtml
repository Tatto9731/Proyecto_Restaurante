@model Proyecto_Restaurante.Models.Factura

@{
    ViewData["Title"] = "Detalle Factura";
}

<div class="card shadow">
    <div class="card-header bg-info text-white">
        <h4 class="mb-0">📄 Detalle de Factura</h4>
    </div>

    <div class="card-body">

        <p><strong>Total:</strong> @Model.Total</p>
        <p><strong>Impuestos:</strong> @Model.Impuestos</p>
        <p><strong>Método de Pago:</strong> @Model.MetodoPago</p>
        <p><strong>Número de Factura:</strong> @Model.NumeroFactura</p>
        <p><strong>Orden:</strong> @Model.Orden?.OrdenId</p>

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">← Volver</a>
            <a asp-action="Edit" asp-route-id="@Model.FacturaId" class="btn btn-warning">Editar</a>
        </div>

    </div>
</div>