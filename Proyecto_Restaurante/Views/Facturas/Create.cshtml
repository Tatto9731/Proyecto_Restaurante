@model Proyecto_Restaurante.Models.Factura

@{
    ViewData["Title"] = "Crear Factura";
}

<div class="card shadow">
    <div class="card-header bg-dark text-white">
        <h4 class="mb-0">🧾 Crear Factura</h4>
    </div>

    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="OrdenId" class="form-label fw-semibold"></label>
                <select asp-for="OrdenId" class="form-select" asp-items="ViewBag.OrdenId" id="OrdenId">
                    <option value="">-- Seleccione una orden --</option>
                </select>
                <span asp-validation-for="OrdenId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Subtotal" class="form-label fw-semibold"></label>
                <input asp-for="Subtotal" class="form-control bg-light" id="Subtotal" readonly />
                <span asp-validation-for="Subtotal" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Impuestos" class="form-label fw-semibold"></label>
                <input asp-for="Impuestos" class="form-control bg-light" id="Impuestos" readonly />
                <div class="form-text">Se calcula automáticamente con un 13%.</div>
                <span asp-validation-for="Impuestos" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Total" class="form-label fw-semibold"></label>
                <input asp-for="Total" class="form-control bg-light fw-bold" id="Total" readonly />
                <span asp-validation-for="Total" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MetodoPago" class="form-label fw-semibold"></label>
                <select asp-for="MetodoPago" class="form-select">
                    <option value="">-- Seleccione método de pago --</option>
                    <option value="Efectivo">Efectivo</option>
                    <option value="Tarjeta">Tarjeta</option>
                    <option value="Sinpe">Sinpe</option>
                    <option value="Transferencia">Transferencia</option>
                </select>
                <span asp-validation-for="MetodoPago" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NumeroFactura" class="form-label fw-semibold"></label>
                <input asp-for="NumeroFactura" class="form-control" placeholder="Déjelo vacío para generar automático" />
                <span asp-validation-for="NumeroFactura" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">← Volver</a>
                <button type="submit" class="btn btn-gold">Crear factura</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        async function cargarMontosOrden() {
            const ordenId = document.getElementById('OrdenId').value;
            const subtotalInput = document.getElementById('Subtotal');
            const impuestosInput = document.getElementById('Impuestos');
            const totalInput = document.getElementById('Total');

            if (!ordenId) {
                subtotalInput.value = '';
                impuestosInput.value = '';
                totalInput.value = '';
                return;
            }

            try {
                const response = await fetch('/Facturas/ObtenerSubtotalOrden?ordenId=' + ordenId);

                if (!response.ok) {
                    subtotalInput.value = '';
                    impuestosInput.value = '';
                    totalInput.value = '';
                    return;
                }

                const data = await response.json();

                subtotalInput.value = Number(data.subtotal).toFixed(2);
                impuestosInput.value = Number(data.impuestos).toFixed(2);
                totalInput.value = Number(data.total).toFixed(2);
            } catch (error) {
                subtotalInput.value = '';
                impuestosInput.value = '';
                totalInput.value = '';
                console.error('Error al obtener montos de la orden:', error);
            }
        }

        document.getElementById('OrdenId').addEventListener('change', cargarMontosOrden);
        window.addEventListener('load', cargarMontosOrden);
    </script>
}