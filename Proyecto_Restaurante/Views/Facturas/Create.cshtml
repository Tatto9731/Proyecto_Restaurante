@model Proyecto_Restaurante.Models.Factura

@{
    ViewData["Title"] = "Crear Factura";
}

<div class="card shadow">
    <div class="card-header bg-dark text-white">
        <h4 class="mb-0">🧾 Crear Factura</h4>
    </div>

    <div class="card-body">
        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="OrdenId" class="form-label fw-semibold"></label>
                <select asp-for="OrdenId" class="form-select" asp-items="ViewBag.OrdenId">
                    <option value="">-- Seleccione una orden --</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Subtotal" class="form-label fw-semibold"></label>
                <input asp-for="Subtotal" class="form-control" id="Subtotal" type="number" step="0.01" min="0" />
            </div>

            <div class="mb-3">
                <label asp-for="Impuestos" class="form-label fw-semibold"></label>
                <input asp-for="Impuestos" class="form-control" id="Impuestos" type="number" step="0.01" min="0" />
            </div>

            <div class="mb-3">
                <label asp-for="Total" class="form-label fw-semibold"></label>
                <input asp-for="Total" class="form-control bg-light fw-bold" id="Total" type="number" readonly />
            </div>

            <div class="mb-3">
                <label asp-for="MetodoPago" class="form-label fw-semibold"></label>
                <select asp-for="MetodoPago" class="form-select">
                    <option value="">-- Seleccione método de pago --</option>
                    <option value="Efectivo">Efectivo</option>
                    <option value="Tarjeta">Tarjeta</option>
                    <option value="Sinpe">Sinpe</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="NumeroFactura" class="form-label fw-semibold"></label>
                <input asp-for="NumeroFactura" class="form-control" placeholder="Déjelo vacío para generar automático" />
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">← Volver</a>
                <button type="submit" class="btn btn-gold">Crear</button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function calcularTotal() {
            let subtotal = parseFloat(document.getElementById('Subtotal').value) || 0;
            let impuestos = parseFloat(document.getElementById('Impuestos').value) || 0;
            let total = subtotal + impuestos;

            document.getElementById('Total').value = total.toFixed(2);
        }

        document.getElementById('Subtotal').addEventListener('input', calcularTotal);
        document.getElementById('Impuestos').addEventListener('input', calcularTotal);

        window.addEventListener('load', calcularTotal);
    </script>
}