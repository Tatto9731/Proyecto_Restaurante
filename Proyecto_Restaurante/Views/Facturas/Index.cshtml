@model IEnumerable<Proyecto_Restaurante.Models.Factura>

@{
    ViewData["Title"] = "Facturación";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">💰 Facturación</h2>
    <a asp-action="Create" class="btn btn-gold">+ Nueva Factura</a>
</div>

<table class="table table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Total</th>
            <th>Impuestos</th>
            <th>Método</th>
            <th># Factura</th>
            <th>Orden</th>
            <th class="text-end">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td class="fw-semibold">@item.Total</td>
                <td>@item.Impuestos</td>
                <td>@item.MetodoPago</td>
                <td>@item.NumeroFactura</td>
                <td>@item.Orden?.OrdenId</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@item.FacturaId" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.FacturaId" class="btn btn-sm btn-info text-white">Ver</a>
                    <a asp-action="Delete" asp-route-id="@item.FacturaId" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>