@model Proyecto_Restaurante.Models.Orden

@{
    ViewData["Title"] = "Eliminar Orden";
}

<div class="card shadow border-danger">
    <div class="card-header bg-danger text-white">
        <h4 class="mb-0">⚠️ Eliminar Orden</h4>
    </div>

    <div class="card-body">

        <p>¿Seguro que deseas eliminar esta orden?</p>

        <ul>
            <li><strong>Fecha:</strong> @Model.Fecha</li>
            <li><strong>Mesa:</strong> @Model.Mesa?.MesaId</li>
            <li><strong>Salonero:</strong> @Model.Salonero?.SaloneroId</li>
        </ul>

        <form asp-action="Delete">
            <input type="hidden" asp-for="OrdenId" />

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-danger">Eliminar</button>
            </div>

        </form>

    </div>
</div>