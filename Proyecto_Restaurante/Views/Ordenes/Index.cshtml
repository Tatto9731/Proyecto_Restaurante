@model IEnumerable<Proyecto_Restaurante.Models.Orden>

@{
    ViewData["Title"] = "Órdenes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">🍽️ Órdenes</h2>
    <a asp-action="Create" class="btn btn-gold">+ Nueva Orden</a>
</div>

<table class="table table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Fecha</th>
            <th>Mesa</th>
            <th>Salonero</th>
            <th class="text-end">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Fecha</td>
                <td>🪑 @item.Mesa?.MesaId</td>
                <td>👨‍🍳 @item.Salonero?.SaloneroId</td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@item.OrdenId" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.OrdenId" class="btn btn-sm btn-info text-white">Ver detalles</a>
                    <a asp-action="Delete" asp-route-id="@item.OrdenId" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>