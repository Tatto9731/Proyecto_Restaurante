<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Restaurante Gourmet</title>

   
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <style>
            body {
                font-family: 'Poppins', sans-serif;
                background-color: #f8f9fa;
            }

       
            .navbar {
                background: linear-gradient(90deg, #1c1c1c, #343a40);
            }

            .navbar-brand {
                font-weight: 600;
                color: #f8d210 !important;
                font-size: 1.4rem;
            }

            .nav-link {
                color: #ffffff !important;
                margin-right: 10px;
                transition: 0.3s;
            }

            .nav-link:hover {
                color: #f8d210 !important;
                transform: scale(1.05);
            }

         
            .btn-gold {
                background-color: #f8d210;
                color: #000;
                border-radius: 25px;
                padding: 5px 15px;
                font-weight: 500;
            }

            .btn-gold:hover {
                background-color: #e5c100;
            }

        
            .container {
                margin-top: 30px;
            }

            main {
                background: white;
                padding: 25px;
                border-radius: 10px;
                box-shadow: 0px 4px 15px rgba(0,0,0,0.1);
            }

         
            footer {
                background-color: #1c1c1c;
                color: #aaa;
                padding: 15px 0;
                text-align: center;
                margin-top: 40px;
            }

            footer a {
                color: #f8d210;
                text-decoration: none;
            }

            footer a:hover {
                text-decoration: underline;
            }
    </style>
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg shadow">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    🍽️ Restaurante Gourmet
                </a>

                <button class="navbar-toggler bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Categorias" asp-action="Index">Categorías</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Productos" asp-action="Index">Menú</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Ordenes" asp-action="Index">Órdenes</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Mesas" asp-action="Index">Mesas</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Reservas" asp-action="Index">Reservas</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Saloneros" asp-action="Index">Saloneros</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Facturas" asp-action="Index">Facturación</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Clientes" asp-action="Index">Clientes</a>
                        </li>

                    </ul>

                  
                    <a class="btn btn-gold" asp-controller="Ordenes" asp-action="Create">
                        Nueva Orden
                    </a>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container">
            <p>&copy; 2026 - Restaurante Gourmet | Sistema de Gestión</p>
            <p>
                <a asp-controller="Home" asp-action="Privacy">Política de Privacidad</a>
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>