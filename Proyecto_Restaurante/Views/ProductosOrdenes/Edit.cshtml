@model Proyecto_Restaurante.Models.ProductoOrden

@{
    ViewData["Title"] = "Editar Producto en Orden";
}

<div class="card shadow">
    <div class="card-header bg-warning">
        <h4 class="mb-0">✏️ Editar Producto en Orden</h4>
    </div>

    <div class="card-body">
        <form asp-action="Edit">

            <input type="hidden" asp-for="ProductoOrdenId" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="OrdenId" class="form-label fw-semibold"></label>
                <select asp-for="OrdenId" class="form-select" asp-items="ViewBag.OrdenId"></select>
            </div>

            <div class="mb-3">
                <label asp-for="ProductoId" class="form-label fw-semibold"></label>
                <select asp-for="ProductoId" class="form-select" asp-items="ViewBag.ProductoId"></select>
            </div>

            <div class="mb-3">
                <label asp-for="Cantidad" class="form-label fw-semibold"></label>
                <input asp-for="Cantidad" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Precio" class="form-label fw-semibold"></label>
                <input asp-for="Precio" class="form-control" />
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">← Volver</a>
                <button type="submit" class="btn btn-gold">Guardar Cambios</button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}