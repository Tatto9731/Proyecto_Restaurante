@model Proyecto_Restaurante.Models.ProductoOrden

@{
    ViewData["Title"] = "Agregar Producto a Orden";
}

<div class="card shadow">
    <div class="card-header bg-dark text-white">
        <h4 class="mb-0">➕ Agregar Producto a Orden</h4>
    </div>

    <div class="card-body">
        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="OrdenId" class="form-label fw-semibold"></label>
                <select asp-for="OrdenId" class="form-select" asp-items="ViewBag.OrdenId">
                    <option value="">-- Seleccione orden --</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="ProductoId" class="form-label fw-semibold"></label>
                <select asp-for="ProductoId" class="form-select" asp-items="ViewBag.ProductoId">
                    <option value="">-- Seleccione producto --</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Cantidad" class="form-label fw-semibold"></label>
                <input asp-for="Cantidad" class="form-control" />
                <span asp-validation-for="Cantidad" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Precio" class="form-label fw-semibold"></label>
                <input asp-for="Precio" class="form-control" />
                <span asp-validation-for="Precio" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">← Volver</a>
                <button type="submit" class="btn btn-gold">Guardar</button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}