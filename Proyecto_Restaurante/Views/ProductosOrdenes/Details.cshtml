@model Proyecto_Restaurante.Models.ProductoOrden

@{
    ViewData["Title"] = "Detalle Producto en Orden";
}

<div class="card shadow">
    <div class="card-header bg-info text-white">
        <h4 class="mb-0">📄 Detalle Producto en Orden</h4>
    </div>

    <div class="card-body">

        <p><strong>Cantidad:</strong> @Model.Cantidad</p>
        <p><strong>Precio:</strong> ₡ @Model.Precio</p>
        <p><strong>Orden:</strong> @Model.Orden?.OrdenId</p>
        <p><strong>Producto:</strong> @Model.Producto?.ProductoId</p>

        <div class="d-flex justify-content-between mt-3">
            <a asp-action="Index" class="btn btn-secondary">← Volver</a>
            <a asp-action="Edit" asp-route-id="@Model.ProductoOrdenId" class="btn btn-warning">Editar</a>
        </div>

    </div>
</div>