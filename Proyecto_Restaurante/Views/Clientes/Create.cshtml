@model Proyecto_Restaurante.Models.Cliente

@{
    ViewData["Title"] = "Nuevo Cliente";
}

<div class="card shadow">
    <div class="card-header bg-dark text-white">
        <h4 class="mb-0">➕ Registrar Cliente</h4>
    </div>

    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Nombre" class="form-label fw-semibold"></label>
                    <input asp-for="Nombre" class="form-control" placeholder="Nombre completo" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Identificacion" class="form-label fw-semibold"></label>
                    <input asp-for="Identificacion" class="form-control" placeholder="Cédula o ID" />
                    <span asp-validation-for="Identificacion" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="CorreoElectronico" class="form-label fw-semibold"></label>
                    <input asp-for="CorreoElectronico" class="form-control" placeholder="correo@email.com" />
                    <span asp-validation-for="CorreoElectronico" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Telefono" class="form-label fw-semibold"></label>
                    <input asp-for="Telefono" class="form-control" placeholder="Teléfono" />
                    <span asp-validation-for="Telefono" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">← Volver</a>
                <button type="submit" class="btn btn-gold">Guardar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}