@model Proyecto_Restaurante.Models.Cliente

@{
    ViewData["Title"] = "Eliminar Cliente";
}

<div class="card shadow border-danger">
    <div class="card-header bg-danger text-white">
        <h4 class="mb-0">⚠️ Eliminar Cliente</h4>
    </div>

    <div class="card-body">
        <p>
            ¿Seguro que deseas eliminar a:
            <strong class="text-danger">@Model.Nombre</strong>?
        </p>

        <ul class="mb-3">
            <li><strong>ID:</strong> @Model.Identificacion</li>
            <li><strong>Correo:</strong> @Model.CorreoElectronico</li>
        </ul>

        <form asp-action="Delete">
            <input type="hidden" asp-for="ClienteId" />

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-danger">Eliminar</button>
            </div>
        </form>
    </div>
</div>